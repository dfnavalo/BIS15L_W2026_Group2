mountains <- c("mount_everest, k2, kangchenjunga, lhotse, makalu")
height_in_feet <- c(29032, 28251, 28169, 27940, 27838)
height_in_meters <- c(8849, 8611, 8586, 8516, 8485)
tallest_mountains <- tibble(mountains, height_in_feet, height_in_meters)
mean(tallest_mountains$height_in_feet)
first_climbed <- c(1953, 1954, 1955, 1956, 1955)
tallest_mountains <- tibble(mountains, height_in_feet, height_in_meters, first_climbed)
