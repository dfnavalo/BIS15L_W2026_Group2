library("tidyverse")
options(scipen=999) #turn off scientific notation
homerange <- read_csv("data/Tamburelloetal_HomeRangeDatabase.csv")
structure(homerange)
ggplot(data=homerange,
mapping=aes(x=class))+
geom_bar(mapping=aes(fill=class))+
labs(title="Individuals in Each Class", x="Class", y="Individuals")
ggplot(data=homerange,
mapping=aes(x=trophic.guild))+
geom_bar(mapping=aes(fill=trophic.guild))+
labs(title="Carnivores vs. Herbivores", x="Trophic Guild", y="Individuals")
names(homerange)
homerange %>%
select(common.name, order, mean.hra.m2, mean.mass.g) %>%
filter(mean.hra.m2>"1000000") %>%
arrange(desc(mean.hra.m2)) %>%
slice_max (mean.hra.m2, n=10)
homerange %>%
select(common.name, order, mean.hra.m2, mean.mass.g) %>%
slice_max (mean.hra.m2, n=1)
homerange %>%
select(common.name, order, mean.hra.m2, mean.mass.g) %>%
slice_min (mean.hra.m2, n=1)
View(homerange)
