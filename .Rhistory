library(tidyverse)
library(janitor)
surgery <- read_csv("data/surgery.csv") %>%
clean_names()
names(surgery)
surgery %>%
filter(race!="NA") %>%
group_by(race) %>%
summarise(
n = n(),
min_age=min(age, na.rm = T),
max_age=max(age, na.rm = T),
mean_age = mean(age, na.rm = T),
median_age = median(age, na.rm = T)
) %>%
arrange(desc(n))
surgery %>%
group_by(mort30) %>%
summarise(
mean_age = mean(age, na.rm = T),
sd_age = sd(age, na.rm = T),
n = n()
)
surgery %>%
group_by(month, mort30) %>%
summarise(
mean_age = mean(age, na.rm = T),
n = n()
)
surgery %>%
filter(gender!="NA") %>%
count(gender)
surgery %>%
filter(gender != "NA") %>%
count(gender) %>%
ggplot(aes(x = gender, y = n, fill = gender)) +
geom_col() +
labs(title = "Number of Males and Females",
x = "Gender",
y = "Count")
glimpse(surgery)
View(surgery)
surgery <- surgery %>%
mutate(high_risk = asa_status %in% c("III", "IV", "V"))
View(surgery)
surgery %>%
group_by(high_risk, hour) %>%
summarize(
mortality_rate = mean(mort30 == "Yes", na.rm = T),
.groups = "drop"
)
surgery %>%
ggplot(aes(x = hour,
y = mort30 == "Yes",
color = high_risk))+
geom_line()+
theme_minimal()
surgery <- surgery %>%
mutate(weekend = weekend %in% c("Sat", "Sun"))
surgery <- surgery %>%
mutate(weekend = dow %in% c("Sat", "Sun"))
surgery %>%
group_by(weekend) %>%
summarize(
mortality_rate = mean(mort30 == "Yes", na.rm = T),
.groups = "drop"
surgery %>%
group_by(weekend) %>%
summarize(
mortality_rate = mean(mort30 == "Yes", na.rm = T),
.groups = "drop")
unique(surgery$dow)
surgery <- surgery %>%
mutate(high_risk = asa_status %in% c("III", "IV", "V"),
hour_group = floor(hour) %>%
group_by(high_risk, hour_group) %>%
summarize(
mortality_rate = mean(mort30 == "Yes", na.rm = T),
.groups = "drop"
)
surgery <- surgery %>%
mutate(high_risk = asa_status %in% c("III", "IV", "V"),
hour_group = floor(hour)) %>%
group_by(high_risk, hour_group) %>%
summarize(
mortality_rate = mean(mort30 == "Yes", na.rm = T),
.groups = "drop"
)
surgery %>%
ggplot(aes(x = hour_group,
y = mortality_rate,
color = high_risk))+
geom_line()+
theme_minimal()
surgery <- surgery %>%
group_by(moonphase) %>%
summarize(
mortality_rate = mean(mort30 == "Yes", na.rm = T),
n = n(),
.groups = "drop")
surgery <- surgery %>%
mutate(weekend = dow %in% c("Sat", "Sun"))
