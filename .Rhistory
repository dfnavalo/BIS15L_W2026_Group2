library(tidyverse)
library(janitor)
surgery <- read_csv("data/surgery.csv") %>%
clean_names()
names(surgery)
surgery %>%
filter(race!="NA") %>%
group_by(race) %>%
summarise(
n = n(),
min_age=min(age, na.rm = T),
max_age=max(age, na.rm = T),
mean_age = mean(age, na.rm = T),
median_age = median(age, na.rm = T)
) %>%
arrange(desc(n))
surgery %>%
group_by(mortality) %>%
summarise(
mean_age = mean(age, na.rm = TRUE),
sd_age = sd(age, na.rm = TRUE),
n = n()
)
View(surgery)
surgery %>%
group_by(mort30) %>%
summarise(
mean_age = mean(age, na.rm = T),
sd_age = sd(age, na.rm = T),
n = n()
)
surgery %>%
group_by(month, mort30) %>%
summarise(
mean_age = mean(age, na.rm = T),
n = n()
)
surgery %>%
count(gender)
surgery %>%
filter(gender!="NA") %>%
count(gender)
surgery %>%
group_by(gender) %>%
summarize(mortality_rate = mean(mort30, na.rm = TRUE)) %>%
ggplot(aes(x = gender, y = mortality_rate)) +
geom_col() +
labs(
title = "30-Day Mortality Rate by Gender",
x = "Gender",
y = "Mortality Rate"
) +
theme_minimal()
surgery %>%
group_by(gender) %>%
summarize(mortality_rate = mean(mort30, na.rm = T)) %>%
ggplot(aes(x= gender, y= mortality_rate))+
geom_point()
surgery %>%
group_by(gender) %>%
summarize(mortality_rate = mean(mort30, na.rm = T)) %>%
ggplot(aes(x= gender, y= mortality_rate))+
geom_col()
surgery %>%
mutate(mort30 = as.numeric(mort30)) %>%
group_by(gender) %>%
summarise(mortality_rate = mean(mort30, na.rm = T)) %>%
ggplot(aes(x = gender, y = mortality_rate)) +
geom_col()
surgery %>%
group_by(month) %>%
summarise(mortality_rate = mean(mort30, na.rm = TRUE)) %>%
ggplot(aes(x = month, y = mortality_rate)) +
geom_col()
surgery %>%
filter(!is.na(month), !is.na(mort30)) %>%
group_by(month) %>%
summarise(deaths = sum(mort30 == 1)) %>%
arrange(desc(deaths))
surgery %>%
filter(mort30 == 1) %>%
count(month, sort = TRUE) %>%
ggplot(aes(x = reorder(month, n), y = n)) +
geom_col() +
coord_flip() +
labs(title = "30-Day Deaths by Month",
x = "Month",
y = "Number of Deaths")
surgery %>%
mutate(mort30 = as.numeric(mort30)) %>%
group_by(gender) %>%
summarise(mortality_rate = mean(mort30, na.rm = T)) %>%
ggplot(aes(x = gender, y = mortality_rate)) +
geom_bar()
surgery %>%
filter(gender != "NA") %>%
count(gender) %>%
ggplot(aes(x = gender, y = n)) +
geom_col() +
labs(title = "Number of Males and Females",
x = "Gender",
y = "Count")
surgery %>%
filter(gender != "NA") %>%
count(gender) %>%
ggplot(aes(x = gender, y = n, fill = gender)) +
geom_col() +
labs(title = "Number of Males and Females",
x = "Gender",
y = "Count")
surgery %>%
filter(gender!="NA") %>%
count(gender)
surgery %>%
filter(mort30 == 1) %>%
count(month, sort = TRUE)
surgery %>%
count(month, sort = TRUE)
View(surgery)
surgery %>%
group_by(month, mort30) %>%
summarise(
mean_age = mean(age, na.rm = T),
n = n()
)
