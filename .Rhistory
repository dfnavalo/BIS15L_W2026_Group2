library(tidyverse)
library(janitor)
surgery <- read_csv("data/surgery.csv") %>%
clean_names()
names(surgery)
surgery %>%
filter(race!="NA") %>%
group_by(race) %>%
summarise(
n = n(),
min_age=min(age, na.rm = T),
max_age=max(age, na.rm = T),
mean_age = mean(age, na.rm = T),
median_age = median(age, na.rm = T)
) %>%
arrange(desc(n))
moon <- surgery %>%
group_by(moonphase) %>%
summarize(
mortality_rate = mean(mort30 == "Yes", na.rm = T),
n = n(),
.groups = "drop") %>%
moon <- surgery %>%
group_by(moonphase) %>%
summarize(
mortality_rate = mean(mort30 == "Yes", na.rm = T),
n = n(),
.groups = "drop")
moon %>%
ggplot(aes(x = moonphase,
y = mortality_rate))+
geom_line()+
theme_minimal()
View(moon)
moon %>%
ggplot(aes(x = moonphase,
y = mortality_rate))+
geom_col()+
theme_minimal()
